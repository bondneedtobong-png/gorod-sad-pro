# ====== Next.js (Vercel) — переменные веб-приложения ======
# Скопируйте в .env (локально) и пропишите в Vercel → Settings → Environment Variables.
# Файл .env в репозиторий НЕ коммитится.

# ---- База данных (Neon / Vercel Postgres) ----
# Pooled-подключение (для приложения, serverless):
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.eu-central-1.aws.neon.tech/neondb?sslmode=require"
# Прямое подключение (для миграций Prisma). Если нет отдельного — продублируйте DATABASE_URL.
DIRECT_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require"

# ---- Админ (создаётся seed-скриптом) ----
ADMIN_EMAIL="admin@gorod-sad.pro"
ADMIN_PASSWORD="смените-на-надёжный-пароль"

# ---- Auth.js (NextAuth v5) ----
# Сгенерировать: `npx auth secret`  (или openssl rand -base64 32)
AUTH_SECRET=""
# Базовый URL приложения (для коллбэков). На проде — домен сайта.
AUTH_URL="http://localhost:3000"

# ---- VK OAuth ----
VK_CLIENT_ID=""
VK_CLIENT_SECRET=""

# ---- Отправка писем (сброс пароля) — Resend ----
RESEND_API_KEY=""
# От кого слать письма (должен быть верифицированный домен в Resend):
EMAIL_FROM="Город-сад <no-reply@gorod-sad.pro>"

# ---- ИИ-консультант (OpenRouter) ----
OPENROUTER_API_KEY=""
# Необязательно — модель (по умолчанию бесплатная):
# OPENROUTER_MODEL="google/gemma-4-26b-a4b-it:free"

# ---- Аналитика (Яндекс.Метрика) ----
# Если пусто — Метрика не подключается. Грузится только после согласия на cookies.
NEXT_PUBLIC_YANDEX_METRIKA_ID=""

# ---- Прочее ----
# Внешний бэкенд FastAPI НЕ нужен — оставьте пустым (фронт использует свои route handlers).
# NEXT_PUBLIC_API_URL=
NEXT_PUBLIC_SITE_URL="https://gorod-sad-pro.vercel.app"
